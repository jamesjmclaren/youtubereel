# YouTube Data API OAuth2 credentials
# Create at: https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Facebook Reels (optional)
# Create a Page Access Token at https://developers.facebook.com/tools/explorer/
# Required permissions: pages_manage_posts, pages_read_engagement, pages_show_list
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
